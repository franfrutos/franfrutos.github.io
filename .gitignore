# Quarto build artifacts (regenerated by `quarto render`)
/.quarto/
/_site/
/_freeze/
_quarto_internal_scss_error.scss

# Generated each render from data/site.yml (scripts/build-meta.mjs)
/_includes/head.html

# Open Graph share cards, Typst→PNG (scripts/build-og.mjs): per-paper + generic
/assets/og/
/assets/og-image.png

# Stamped each render with content-hash cache-busters (scripts/stamp-scripts.mjs)
/_includes/scripts.html

# Generated on each render from the YAML sources (data/papers.yml, data/journey.yml)
/assets/data/research.js
/assets/data/journey.js
/assets/data/city-coords.js
/research/*/

# CV page (PDF source) + on-site HTML page, generated from data/cv.yml + papers.yml
/cv/cv.qmd
/cv/index.qmd
# Intermediate Typst kept (keep-typ) so build-cv-dark.mjs can recompile the dark PDF
/cv/cv.typ

# Private CV overlay + generated private PDFs (local only, never published)
/.private/

# Geocoder download cache (the dataset itself is committed under scripts/data/)
scripts/.geonames-cache/

# Handoff source bundle (kept locally, not part of the site)
/_extracted/
/Personal webpage.zip

# Local tooling (Claude Code) + Quarto's root-level generated libs
/.claude/
/site_libs/

# OS / editor cruft
.DS_Store
Thumbs.db
*.log
